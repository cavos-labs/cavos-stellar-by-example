# Copy this file to .env.local and fill in your own values.
# .env.local is git-ignored — never commit it, and never commit real
# secrets, seed phrases, private keys, or API secrets to this repo.
#
# See "Get a Cavos App ID" in this app's README.md (and the repo root
# README.md) for the full setup steps.

# Your Cavos application's App ID, from the Cavos dashboard.
# Public by design (safe to expose in client-side code), but still keep it
# out of source control — set it locally in .env.local only.
# Leave unset to run the app in demo mode with mock data.
NEXT_PUBLIC_CAVOS_APP_ID=

# Stellar network this example targets. Defaults to "testnet" when unset.
# Use "testnet" for local development; only switch to "mainnet" once you
# understand the real-fund implications.
NEXT_PUBLIC_CAVOS_NETWORK=testnet
